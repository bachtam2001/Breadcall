{
  "name": "breadcall-ndi-client",
  "version": "1.0.0",
  "description": "BreadCall NDI Desktop Client - Receive WebRTC streams and output NDI",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "webrtc",
    "ndi",
    "broadcast",
    "live-production",
    "breadcall"
  ],
  "author": "BreadCall",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "wrtc": "^0.4.7",
    "node-fetch": "^2.7.0"
  },
  "build": {
    "appId": "com.breadcall.ndi-client",
    "productName": "BreadCall NDI Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  }
}
