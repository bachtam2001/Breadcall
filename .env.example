# Signaling Server
PORT=3000
NODE_ENV=development

# Admin Panel
ADMIN_PASSWORD=admin
SESSION_SECRET=your-session-secret-here
USE_SECURE_COOKIES=false
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:8080

# TURN Server
TURN_SECRET=your-turn-secret-here
TURN_REALM=BreadCall
TURN_PORT=3478
EXTERNAL_IP=localhost

# SSL (for production)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Docker Deployment
SIGNALING_PORT=3000
SIGNALING_REPLICAS=2
WEB_REPLICAS=2
EXTERNAL_IP_1=server1.example.com

# Coturn
COTURN_USER=turnuser
COTURN_PASSWORD=turnpassword
