{
  "name": "breadcall-srt-gateway",
  "version": "1.0.0",
  "description": "BreadCall SRT Gateway - Receive WebRTC streams and output SRT",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "docker:build": "docker build -t breadcall-srt-gateway .",
    "docker:run": "docker run -p 8080:8080 -p 9000-9100:9000-9100/udp breadcall-srt-gateway"
  },
  "keywords": [
    "srt",
    "webrtc",
    "streaming",
    "broadcast",
    "breadcall"
  ],
  "author": "BreadCall",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.0",
    "wrtc": "^0.4.7",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "node-pre-gyp": "^0.17.0",
    "nodemon": "^3.0.2"
  }
}
